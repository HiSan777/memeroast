# WalletConnect / RainbowKit
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_SITE_URL=https://memeroast.xyz

# Public builder wallet only. Never put a private key here.
NEXT_PUBLIC_BUILDER_WALLET_ADDRESS=
NEXT_PUBLIC_PAYMENT_RECEIVER_ADDRESS=0x87CE124f9c32B83b54255583E2a39CB6bcEADc46

# Real image generation. Keep provider keys server-side only.
# Fal.ai / Replicate / Grok-compatible endpoints can be used here.
# Example Fal endpoint shape depends on the model you pick in Fal dashboard.
NEXT_PUBLIC_REAL_IMAGE_ENABLED=true
IMAGE_GENERATION_ENDPOINT=
IMAGE_GENERATION_API_KEY=
IMAGE_GENERATION_MODEL=
IMAGE_GENERATION_PAYLOAD_MODE=openai

# AI provider keys for server-side routes in later steps.
GROK_API_KEY=
GROK_IMAGE_API_KEY=
FLUX_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# IPFS storage provider for final meme assets.
PINATA_JWT=
IPFS_GATEWAY_URL=https://gateway.pinata.cloud
IPFS_API_KEY=
IPFS_API_SECRET=

# Cloudinary unsigned upload preset for generated meme images and metadata fallback.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# Future Arc/Circle integration values.
NEXT_PUBLIC_ARC_TESTNET_RPC=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_CHAIN_ID=5042002

# Optional. Set this only after deploying contracts/MemeRoastHistory.sol.
# The app calls recordRoast(metadataUri) when this is configured.
NEXT_PUBLIC_MEMEROAST_HISTORY_CONTRACT=
NEXT_PUBLIC_MEMEROAST_HISTORY_START_BLOCK=0
